# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (secrets)
.env*.local
.env
.env.development.local
.env.test.local
.env.production.local

# Explicitly allow env template files to be committed
!.env.example
!.env.template
# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo

# AI Config Files
AGENTS.md
CLAUDE.md
.cursorrules
